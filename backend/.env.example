PORT=4000
# --- LLM engine ---
# OpenAI-compatible chat completions endpoint. The base URL is the host
# root; the runner appends /chat/completions and sends a stream:true
# request. Examples:
#   OpenAI proxy / OpenRouter / Together:  https://openrouter.ai/api/v1
#   Ollama (local):                        http://ollama:11434/v1
#   Custom gateway:                        https://your-host/v1
LLM_BASE_URL=https://ai.enpiistudio.com/v1
LLM_API_KEY=sk-your-key-here
# Default model id sent when the /models registry has no entry that
# matches the requested key. Operator-controlled via /models; this is
# only the fallback used by the seeded 'workspace' entry.
LLM_DEFAULT_MODEL=workspace
# Per-turn timeout for the upstream LLM (ms). The runner aborts and
# emits a synthetic 'result' with is_error=true when this fires.
LLM_TIMEOUT_MS=120000
# Which engine to run. 'llm' (default) talks HTTP to LLM_BASE_URL;
# 'claude' spawns the legacy Claude CLI binary — kept here so an
# operator can roll back without code edits if the new path misbehaves.
LLM_ENGINE=llm
# Skills directory. Default $HOME/.enllm/skills. Anything stored here
# is exposed to the LLM via Skill.list / Skill.read tools and persists
# in the enllm-skills named volume.
ENLLM_SKILLS_DIR=

# --- Storage / DB / auth (unchanged) ---
DB_PATH=./data/claude-web.db
STORAGE_PATH=./storage/attachments
MAX_ATTACHMENT_SIZE_MB=10
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
BOOTSTRAP_USERNAME=admin
BOOTSTRAP_PASSWORD=admin12345